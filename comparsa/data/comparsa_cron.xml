<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- noupdate="1" evita que las actualizaciones del módulo sobreescriban
    cambios manuales del administrador (fecha, activo, etc.) -->
  <data noupdate="1">

    <!-- Cron que genera cuotas el día 1 de cada mes -->
    <record id="ir_cron_comparsa_generate_fees" model="ir.cron">
      <field name="name">Comparsa: Generar cuotas periódicas</field>
      <field name="model_id" ref="model_comparsa_charge"/>
      <field name="state">code</field>
      <field name="code">model._cron_generate_fees()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">months</field>
      <field name="active">True</field>
      <!-- Próxima ejecución: día 1 del mes siguiente a la instalación -->
      <field name="nextcall">2026-03-01 06:00:00</field>
    </record>

  </data>
</odoo>
