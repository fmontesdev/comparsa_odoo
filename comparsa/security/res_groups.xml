<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">

    <!-- Gestor: CRUD en modelos operacionales -->
    <!-- Implica base.group_user para que cualquier gestor sea usuario autenticado y vea la app -->
    <record id="group_manager" model="res.groups">
      <field name="name">Gestor</field>
      <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Administrador: gestor + gestión de catálogos de configuración -->
    <record id="group_admin" model="res.groups">
      <field name="name">Administrador</field>
      <!-- El grupo Administrador hereda todos los permisos del grupo Gestor -->
      <field name="implied_ids" eval="[(4, ref('group_manager'))]"/>
    </record>

  </data>
</odoo>
