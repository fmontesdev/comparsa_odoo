<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">

    <!-- Crea la categoría de módulo "Comparsa" en el selector de grupos de usuarios -->
    <record id="module_category_comparsa" model="ir.module.category">
      <field name="name">Comparsa</field>
      <field name="sequence">100</field>
    </record>

    <!-- Gestor: CRUD en modelos operacionales -->
    <record id="group_manager" model="res.groups">
      <field name="name">Gestor</field>
      <field name="category_id" ref="module_category_comparsa"/>
    </record>

    <!-- Administrador: gestor + gestión de catálogos de configuración -->
    <record id="group_admin" model="res.groups">
      <field name="name">Administrador</field>
      <field name="category_id" ref="module_category_comparsa"/>
      <!-- El grupo Administrador hereda todos los permisos del grupo Gestor (4: sin crear ni borrar nada) -->
      <field name="implied_ids" eval="[(4, ref('group_manager'))]"/>
    </record>

  </data>
</odoo>
