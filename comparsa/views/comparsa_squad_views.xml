<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Vista búsqueda -->
    <record id="comparsa_squad_view_search" model="ir.ui.view">
      <field name="name">comparsa.squad.view.search</field>
      <field name="model">comparsa.squad</field>
      <field name="arch" type="xml">
        <search string="Buscar escuadras">
          <field name="name"/>
          <filter string="Archivadas" name="filter_archivadas" domain="[('active', '=', False)]"/>
        </search>
      </field>
    </record>

    <!-- Vista lista -->
    <record id="comparsa_squad_view_list" model="ir.ui.view">
      <field name="name">comparsa.squad.view.list</field>
      <field name="model">comparsa.squad</field>
      <field name="arch" type="xml">
        <list string="Escuadras">
          <field name="name"/>
          <field name="active" optional="hide"/>
        </list>
      </field>
    </record>

    <!-- Vista formulario -->
    <record id="comparsa_squad_view_form" model="ir.ui.view">
      <field name="name">comparsa.squad.view.form</field>
      <field name="model">comparsa.squad</field>
      <field name="arch" type="xml">
        <form string="Escuadra">
          <sheet>
            <!-- Ribbon de estado (archivada) -->
            <widget name="web_ribbon" title="Archivada" bg_color="text-bg-danger" invisible="active"/>
            <field name="active" invisible="True"/>
            
            <!-- Sección superior: nombre de la escuadra -->
            <div class="oe_title">
              <label for="name"/>
              <h1>
                <field name="name" placeholder="Nombre de la escuadra"/>
              </h1>
            </div>
          </sheet>
        </form>
      </field>
    </record>

  </data>
</odoo>
