<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Acción para comparsistas -->
    <record id="comparsa_member_action" model="ir.actions.act_window">
      <field name="name">Miembros</field>
      <field name="res_model">comparsa.member</field>
      <field name="view_mode">list,kanban,form</field>
      <!-- Mensaje para cuando no hay miembros -->
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Crea el primer miembro
        </p>
      </field>
    </record>

    <!-- Acción para escuadras -->
    <record id="comparsa_squad_action" model="ir.actions.act_window">
      <field name="name">Escuadras</field>
      <field name="res_model">comparsa.squad</field>
      <field name="view_mode">list,form</field>
      <!-- Mensaje para cuando no hay escuadras -->
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Crea la primera escuadra
        </p>
      </field>
    </record>

    <!-- Acción para regímenes -->
    <record id="comparsa_regime_action" model="ir.actions.act_window">
      <field name="name">Regímenes</field>
      <field name="res_model">comparsa.member.regime.type</field>
      <field name="view_mode">list,form</field>
      <!-- Mensaje para cuando no hay regímenes -->
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Crea el primer régimen
        </p>
      </field>
    </record>

    <!-- Acción para cargos -->
    <record id="comparsa_role_action" model="ir.actions.act_window">
      <field name="name">Cargos</field>
      <field name="res_model">comparsa.role</field>
      <field name="view_mode">list,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Crea el primer cargo
        </p>
      </field>
    </record>

    <!-- Acción para asignaciones de cargo -->
    <record id="comparsa_role_assignment_action" model="ir.actions.act_window">
      <field name="name">Asignaciones de Cargos</field>
      <field name="res_model">comparsa.role.assignment</field>
      <field name="view_mode">list,form</field>
      <field name="context">{'search_default_filter_vigentes': 1}</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Asigna el primer cargo a un miembro
        </p>
      </field>
    </record>

    <!-- Acción para actos -->
    <record id="comparsa_event_action" model="ir.actions.act_window">
      <field name="name">Actos</field>
      <field name="res_model">comparsa.event</field>
      <field name="view_mode">list,calendar,form</field>
      <field name="context">{'search_default_filter_vigentes': 1}</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Crea el primer acto
        </p>
      </field>
    </record>

    <!-- Acción para categorías de acto -->
    <record id="comparsa_event_category_action" model="ir.actions.act_window">
      <field name="name">Categorías de Actos</field>
      <field name="res_model">comparsa.event.category</field>
      <field name="view_mode">list,kanban,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Crea la primera categoría de acto
        </p>
      </field>
    </record>

    <!-- Acción para logística de escuadras -->
    <record id="comparsa_squad_event_action" model="ir.actions.act_window">
      <field name="name">Logística de Escuadras</field>
      <field name="res_model">comparsa.squad.event</field>
      <field name="view_mode">list,kanban,form</field>
      <field name="context">{'search_default_filter_vigentes': 1}</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Asigna escuadras a un acto festivo
        </p>
      </field>
    </record>

    <!-- Acción para inscripciones -->
    <record id="comparsa_event_registration_action" model="ir.actions.act_window">
      <field name="name">Inscripciones</field>
      <field name="res_model">comparsa.event.registration</field>
      <field name="view_mode">list,kanban,form</field>
      <field name="context">
        {'search_default_filter_confirmed': 1,
        'search_default_filter_vigentes': 1}
      </field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          No hay inscripciones registradas
        </p>
      </field>
    </record>

    <!-- Menús -->
    <menuitem id="comparsa_menu_root" name="Comparsa">
      <menuitem id="comparsa_menu_members" name="Miembros" sequence="10">
        <menuitem id="comparsa_menu_member_list" action="comparsa_member_action"/>
        <menuitem id="comparsa_menu_squad" action="comparsa_squad_action"/>
        <menuitem id="comparsa_menu_regime" action="comparsa_regime_action"/>
        <menuitem id="comparsa_menu_role" action="comparsa_role_action"/>
        <menuitem id="comparsa_menu_role_assignment" action="comparsa_role_assignment_action"/>
      </menuitem>
      <menuitem id="comparsa_menu_events" name="Actos" sequence="20">
        <menuitem id="comparsa_menu_event_list" action="comparsa_event_action" sequence="10"/>
        <menuitem id="comparsa_menu_event_category" action="comparsa_event_category_action" sequence="20"/>
        <menuitem id="comparsa_menu_squad_event" action="comparsa_squad_event_action" sequence="30"/>
        <menuitem id="comparsa_menu_event_registration" action="comparsa_event_registration_action" sequence="40"/>
      </menuitem>
      <!-- <menuitem id="comparsa_menu_config" name="Configuración" sequence="90">
      </menuitem> -->
    </menuitem>

  </data>
</odoo>
